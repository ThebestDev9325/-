rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read, create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /nicknames/{nicknameKey} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'nickname', 'ownerId', 'createdAt'
        ])
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.nickname is string
        && request.resource.data.nickname.size() >= 2
        && request.resource.data.nickname.size() <= 12
        && request.resource.data.createdAt == request.time;
      allow update: if signedIn()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['createdAt'])
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.nickname == resource.data.nickname
        && request.resource.data.createdAt == request.time;
      allow delete: if false;
    }

    match /users/{userId}/records/{recordId} {
      allow read, create, update, delete: if signedIn() && request.auth.uid == userId;
    }

    match /sharedPosts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if signedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['reactions', 'reactedBy', 'reportCount', 'reportedBy']);
      allow delete: if signedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /storyFeedback/{storyId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'storyId', 'likes', 'unsure', 'dislikes', 'total', 'updatedAt'
        ])
        && request.resource.data.storyId == storyId
        && request.resource.data.likes is int
        && request.resource.data.unsure is int
        && request.resource.data.dislikes is int
        && request.resource.data.total == 1
        && request.resource.data.likes
          + request.resource.data.unsure
          + request.resource.data.dislikes == 1;
      allow update: if signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'likes', 'unsure', 'dislikes', 'total', 'updatedAt'
        ])
        && request.resource.data.likes - resource.data.likes in [0, 1]
        && request.resource.data.unsure - resource.data.unsure in [0, 1]
        && request.resource.data.dislikes - resource.data.dislikes in [0, 1]
        && request.resource.data.total == resource.data.total + 1
        && request.resource.data.likes
          + request.resource.data.unsure
          + request.resource.data.dislikes == request.resource.data.total;
      allow delete: if false;
    }
  }
}
