rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /users/{userId}/records/{recordId} {
      allow read, create, update, delete: if signedIn() && request.auth.uid == userId;
    }

    match /sharedPosts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if signedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['reactions', 'reactedBy', 'reportCount', 'reportedBy']);
      allow delete: if signedIn() && resource.data.ownerId == request.auth.uid;
    }
  }
}
